local function loadConfig()
    if not readfile or not isfile then
        notify(I.warn .. " Save", "Executor sem readfile/isfile.", 4)
        return
    end

    local path = "UnboxingHub/Saves/" .. saveName .. ".json"
    if not isfile(path) then
        notify(I.warn .. " Save", "Save nao encontrado: " .. saveName, 3)
        return
    end

    local ok, data = pcall(function()
        return HttpService:JSONDecode(readfile(path))
    end)
    if not ok or type(data) ~= "table" then
        notify(I.warn .. " Save", "Save invalido.", 3)
        return
    end

    for k, v in pairs(data.State or {}) do State[k] = v end
    if type(data.autoCrates) == "table" then
        for crateId, enabled in pairs(data.autoCrates) do
            autoCrates[crateId] = enabled == true
        end
    end
    if data.sellRarities then sellRarities = data.sellRarities end
    crateAmount = data.crateAmount or crateAmount
    autoCrateDelay = data.autoCrateDelay or autoCrateDelay
    autoRushWorld = data.autoRushWorld or autoRushWorld
    autoAttackDelay = data.autoAttackDelay or autoAttackDelay
    autoAttackPriority = data.autoAttackPriority or autoAttackPriority
    autoSellDelay = data.autoSellDelay or autoSellDelay
    merchantDelay = data.merchantDelay or merchantDelay
    crateBurstAmount = data.crateBurstAmount or crateBurstAmount
    crateOpenLimit = data.crateOpenLimit or crateOpenLimit
    webhookUrl = data.webhookUrl or webhookUrl
    webhookDelayMinutes = data.webhookDelayMinutes or webhookDelayMinutes
