local function makeStubTab(label)
    local stub = {}

    local function noop()
        return nil
    end

    stub.CreateSection = noop
    stub.CreateToggle = noop
    stub.CreateButton = noop
    stub.CreateInput = noop
    stub.CreateDropdown = noop
    stub.CreateSlider = noop
    stub.CreateParagraph = noop

    warn("UnboxingHub: usando aba fallback:", tostring(label))
    return stub
end

local function protectTab(tab, label)
    if type(tab) ~= "table" then
        return makeStubTab(label)
    end

    for _, methodName in ipairs({
        "CreateSection",
        "CreateToggle",
        "CreateButton",
        "CreateInput",
        "CreateDropdown",
        "CreateSlider",
        "CreateParagraph",
    }) do
        local rawMethod = tab[methodName]

        if type(rawMethod) == "function" then
            tab[methodName] = function(self, ...)
                local ok, result = pcall(rawMethod, self, ...)
                if not ok then
                    warn("UnboxingHub UI falhou em " .. tostring(label) .. ":" .. methodName, result)
                end
                return ok and result or nil
            end
        else
            tab[methodName] = function()
                warn("UnboxingHub UI sem metodo " .. tostring(methodName) .. " em " .. tostring(label))
                return nil
            end
        end
    end

    return tab
end

