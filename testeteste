local function getWebhookTimestamp()
    local ok, stamp = pcall(function()
        return os.date("!%Y-%m-%dT%H:%M:%SZ")
    end)

    return ok and stamp or nil
end

local function formatWebhookDict(tbl, emptyText, limit)
    local items = {}

    for name, count in pairs(tbl or {}) do
        table.insert(items, {
            Name = tostring(name),
            Count = tonumber(count) or 0,
        })
    end

    table.sort(items, function(a, b)
        if a.Count == b.Count then
            return a.Name < b.Name
        end

        return a.Count > b.Count
    end)

    if #items == 0 then
        return emptyText or "Nenhum registro ainda."
    end

    local lines = {}
    local maxItems = limit or 8

    for i, item in ipairs(items) do
        if i > maxItems then
            table.insert(lines, "+ mais " .. tostring(#items - maxItems) .. " registros...")
            break
        end

        table.insert(lines, "`" .. item.Name .. "` x**" .. formatNumber(item.Count) .. "**")
    end

    local text = table.concat(lines, "\n")
    if #text > 1000 then
        text = text:sub(1, 997) .. "..."
    end

    return text
end

