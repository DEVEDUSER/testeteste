local function shouldSellItem(invItem, category)
    if not invItem then return false end
    if invItem.IsEquipped or invItem.IsFavorite or invItem.Locked then return false end

    local data = getItemData(invItem)
    local rarity = getRarityName(data)
    return rarity and sellRarities[category] and sellRarities[category][rarity] == true
end

local function protectSpecialItems()
    if not PlayerData or not PlayerData.data then return end

    for _, category in ipairs({ "Hats", "Pets", "Perks" }) do
        local storage = PlayerData.data[category]
        if storage then
            for uid, invItem in pairs(storage) do
                if autoFavoriteRareDrops and isRareDrop(invItem) then
                    favoriteOrLockItem(category, uid)
                    invItem.IsFavorite = true
                    invItem.Locked = true
                elseif category == "Perks" and autoFavoriteGoodPerks and getBestPerkStat(invItem) >= perkFavoriteMinStat then
                    favoriteOrLockItem(category, uid)
                    invItem.IsFavorite = true
                    invItem.Locked = true
                end
            end
        end
    end
end

local function sellInventoryCategory(category)
    if not PlayerData or not PlayerData.data then return end

    local storage = PlayerData.data[category]
    if not storage then return end

    local list = {}

    for uid, invItem in pairs(storage) do
        local protected = false

        if autoFavoriteRareDrops and isRareDrop(invItem) then
            favoriteOrLockItem(category, uid)
            invItem.IsFavorite = true
            invItem.Locked = true
            protected = true
        end

        if category == "Perks" and autoFavoriteGoodPerks and getBestPerkStat(invItem) >= perkFavoriteMinStat then
            favoriteOrLockItem(category, uid)
            invItem.IsFavorite = true
            invItem.Locked = true
            protected = true
        end

        if not protected and shouldSellItem(invItem, category) then
            table.insert(list, uid)
        end
    end

    if (category == "Hats" or category == "Pets") and #list >= countDict(storage) then
        table.remove(list)
    end

    if #list <= 0 then return end

    local ok, result = pcall(function()
        return RF.SellItems:InvokeServer(list, category)
    end)

    if ok and result then
        Stats.itemsSold = Stats.itemsSold + #list
        if category == "Hats" then Stats.hatsSold = Stats.hatsSold + #list end
        if category == "Pets" then Stats.petsSold = Stats.petsSold + #list end
        if category == "Perks" then Stats.perksSold = Stats.perksSold + #list end
        notify(I.check .. " Auto Sell", "Vendeu " .. tostring(#list) .. " " .. category, 2)
    end
end

local function getNearestBox()
    if not BoxController then return nil end

    local char = player.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not root then return nil end

    local field = BoxController.GetCurrentField(root.Position)
    if not field then return nil end

    local nearest
    local nearestDist = math.huge
    local boxes = field.VisibleBoxes or field.Boxes or {}

    for _, box in pairs(boxes) do
        if box and box.CFrame and box.Health and box.Damage then
            if box.Health > box.Damage and not box.IsOpen then
                local dist = (box.CFrame.Position - root.Position).Magnitude
                if dist < nearestDist then
                    nearest = box
                    nearestDist = dist
                end
            end
        end
    end

    return nearest
end

local function buildRoutePoints(center, radius, step)
    local points = {}

    for x = -radius, radius, step do
        local row = {}

        for z = -radius, radius, step do
            if Vector3.new(x, 0, z).Magnitude <= radius then
                table.insert(row, center + Vector3.new(x, 0, z))
            end
        end

        if math.floor((x + radius) / step) % 2 == 1 then
            local rev = {}
            for i = #row, 1, -1 do table.insert(rev, row[i]) end
            row = rev
        end

        for _, p in ipairs(row) do table.insert(points, p) end
    end

    return points
end

local function startTPCameraRoute()
    if tpConn then tpConn:Disconnect() tpConn = nil end

    local char = player.Character or player.CharacterAdded:Wait()
    local root = char:WaitForChild("HumanoidRootPart")
    lockedCameraCenter = lockedCameraCenter or root.Position

    routePoints = buildRoutePoints(lockedCameraCenter, routeRadius, routeStep)
    routeIndex = 1

    tpConn = RunService.Heartbeat:Connect(function()
        if not State.tpCamera then return end

        local c = player.Character
        local r = c and c:FindFirstChild("HumanoidRootPart")
        local h = c and c:FindFirstChildOfClass("Humanoid")
        if not r or not h or #routePoints == 0 then return end

        local target = routePoints[routeIndex]
        local flatR = Vector3.new(r.Position.X, lockedCameraCenter.Y, r.Position.Z)
        local flatT = Vector3.new(target.X, lockedCameraCenter.Y, target.Z)

        if (flatR - flatT).Magnitude <= 8 then
            routeIndex = routeIndex + 1
            if routeIndex > #routePoints then routeIndex = 1 end
            target = routePoints[routeIndex]
        end

        h:MoveTo(target)
    end)
end

