            Last = info.Last or "None",
        })
    end

    table.sort(items, function(a, b) return a.Calls > b.Calls end)
    if #items == 0 then return "Nenhum remote usado ainda." end

    local lines = {}
    for i, info in ipairs(items) do
        if i > (limit or 8) then break end
        table.insert(lines, info.Name .. " | calls " .. tostring(info.Calls) .. " | ok " .. tostring(info.Success) .. " | fail " .. tostring(info.Failed))
    end

    return table.concat(lines, "\n")
end

