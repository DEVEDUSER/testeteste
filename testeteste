    while task.wait(0.5) do
        local now = os.clock()

        if State.autoClose and now - lastCloseAt >= 2 then
            lastCloseAt = now
            pcall(function()
                if hasOpenPage() and StateUtil and StateUtil.ClosePage then StateUtil.ClosePage() end
            end)
        end

        if State.autoCloseRushResults and now - lastCloseAt >= 2 then
            lastCloseAt = now
            pcall(function()
                if RE:FindFirstChild("ClaimBoxRush") then RE.ClaimBoxRush:FireServer() end
                if StateUtil and StateUtil.ClosePage then StateUtil.ClosePage("BoxRushResults") end
            end)
        end

        if State.autoEasterRush and now - lastEasterRushAt >= 8 then
            lastEasterRushAt = now
            pcall(function()
                local box = workspace:FindFirstChild("Easter")
                if box and box:FindFirstChild("EasterBoxRush") then
                    recordRush("Easter Rush")
                    RE.StartBoxRush:FireServer(box.EasterBoxRush)
                end
            end)
        end

        if State.autoGoldRush and now - lastGoldRushAt >= 8 then
            lastGoldRushAt = now
            pcall(function()
                local areas = workspace:FindFirstChild("Areas")
                local goldMine = areas and areas:FindFirstChild("23_GoldMine")
                if goldMine and goldMine:FindFirstChild("GoldRush") then
                    recordRush("Gold Rush")
                    RE.StartBoxRush:FireServer(goldMine.GoldRush, autoRushWorld)
                end
            end)
        end

        if State.autoPerk and now - lastPerkAt >= 12 then
            lastPerkAt = now
            pcall(forceActivateEquippedPerks)
        end

        if now - lastRewardAt >= 5 then
            lastRewardAt = now

            if State.autoClaim then
                for i = 1, 12 do pcall(function() RE.ClaimPlaytimeReward:FireServer(i) end) task.wait(0.05) end
            end

            if State.autoBP then
                for i = 1, 6 do pcall(function() RE.ClaimBattlePassTask:FireServer(i) end) task.wait(0.05) end
            end

            if State.autoDaily then pcall(function() RE.ClaimLoginReward:FireServer() end) end
            if State.autoAch then pcall(function() RE.ClaimAllAchievements:FireServer() end) end
            if State.autoClaimDamageQuest then claimDamageQuest() end
        end
    end
end)

