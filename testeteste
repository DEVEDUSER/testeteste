local function favoriteOrLockItem(category, uid)
    pcall(function()
        if RE:FindFirstChild("Favorite") then
            RE.Favorite:FireServer(uid, category)
        elseif RE:FindFirstChild("FavoriteItem") then
            RE.FavoriteItem:FireServer(category, uid, true)
        elseif RE:FindFirstChild("LockItem") then
