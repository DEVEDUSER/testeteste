local Rayfield
do
    local ok, result = pcall(function()
        local source = game:HttpGet("https://sirius.menu/rayfield", true)
        local loader = loadstring or load
        if type(loader) ~= "function" then
            error("Executor sem loadstring/load.")
        end

        local fn, loadErr = loader(source)
        if type(fn) ~= "function" then
            error(loadErr or "Rayfield retornou codigo invalido.")
        end

        return fn()
    end)

    if ok and result then
        Rayfield = result
    else
        warn("Falha ao carregar Rayfield:", result)
        return
    end
end

