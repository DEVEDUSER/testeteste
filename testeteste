local function getLoadedAreaList()
    local result = {}
    local areas = workspace:FindFirstChild("Areas")
    if not areas then return result end

    for _, area in ipairs(areas:GetChildren()) do
        local index = getAreaIndexFromModel and getAreaIndexFromModel(area) or nil
        table.insert(result, {
            Index = index or 999999,
            Name = tostring(area.Name),
            Model = area,
        })
    end

    table.sort(result, function(a, b)
        if a.Index == b.Index then return a.Name < b.Name end
        return a.Index < b.Index
    end)

    return result
end

local function getLoadedAreasText(limit)
    local lines = {}
    local maxItems = limit or 12

    for i, info in ipairs(getLoadedAreaList()) do
        if i > maxItems then
            table.insert(lines, "+ mais " .. tostring(#getLoadedAreaList() - maxItems) .. " areas...")
            break
        end

        table.insert(lines, tostring(info.Index ~= 999999 and info.Index or "?") .. " - " .. info.Name)
    end

    if #lines == 0 then return "Nenhuma area carregada." end
    return table.concat(lines, "\n")
end

