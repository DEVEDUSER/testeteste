        local char = player.Character
        local root = char and char:FindFirstChild("HumanoidRootPart")
        if not root then return end
        local closest, dist
        local areas = workspace:FindFirstChild("Areas")
        if areas then
            for _, obj in ipairs(areas:GetChildren()) do
                local center = getModelCenter(obj)
                if center then
                    local d = (center - root.Position).Magnitude
                    if not dist or d < dist then closest, dist = obj, d end
                end
            end
        end
        notify(I.map .. " Area Debug", closest and (closest:GetFullName() .. " | " .. math.floor(dist)) or "Nenhuma area achada.", 6)
    end,
})

