task.spawn(function()
    while task.wait(autoAttackDelay) do
        if not State.paused and State.autoAttackBoxes then
            safeRun("AutoAttack", function()
                if os.clock() - lastTeleportAt < 0.4 then return end

                local box = getNearestBox()
                if box and box.Field and box.Field.Id and box.Id then
                    lastAttackHadTargetAt = os.clock()
                    attacksThisSecond = attacksThisSecond + 1
                    safeFire("AutoAttack", RE:FindFirstChild("AttackBox"), "AttackBox", 0.01, box.Field.Id, box.Id, Clock and Clock.now() or os.clock())
                elseif State.autoAttackAdaptive then
                    task.wait(0.15)
                end
            end)
        end
    end
end)

task.spawn(function()
    while task.wait(autoSellDelay) do
        if not State.paused then
            protectSpecialItems()
            if State.autoSellHats then safeRun("AutoSell Hats", function() sellInventoryCategory("Hats") end) end
            if State.autoSellPets then safeRun("AutoSell Pets", function() sellInventoryCategory("Pets") end) end
            if State.autoSellPerks then safeRun("AutoSell Perks", function() sellInventoryCategory("Perks") end) end
        end
    end
end)

task.spawn(function()
    while task.wait(autoCrateDelay) do
        if not State.paused then
            local selling = State.autoSellHats or State.autoSellPets or State.autoSellPerks
            local timeExpired = crateStopAt > 0 and os.clock() >= crateStopAt
            local limitReached = crateOpenLimit > 0 and Stats.cratesOpened >= crateOpenLimit

            if timeExpired or limitReached then
                for crateId in pairs(autoCrates) do autoCrates[crateId] = false end
                notify(I.stop .. " Crates", "Auto crates parou pelo limite configurado.", 3)
            elseif not selling then
                for crateId, enabled in pairs(autoCrates) do
                    if enabled then
                        protectSpecialItems()
                        openCrateAndTrack(crateId, crateAmount)
                        task.wait(0.15)
                    end
                end
            end
        end
    end
end)

