local function getBestPerkStat(invItem)
    if not invItem then return 0 end

    local boosts = invItem.boosts or invItem.Boosts or invItem.stats or invItem.Stats
    if StatsModule and StatsModule.CalculatePerkScore and boosts then
        local ok, score = pcall(function()
            return StatsModule.CalculatePerkScore(boosts)
        end)
        if ok and type(score) == "number" then
            return score
        end
    end

    local best = 0
    local function scan(v)
        if type(v) == "number" then
            if v > best then best = v end
        elseif type(v) == "table" then
            for _, x in pairs(v) do scan(x) end
        end
    end

    scan(invItem.Stats)
    scan(invItem.Stat)
    scan(invItem.Modifiers)
    scan(invItem.Boosts)
    scan(invItem.Multiplier)
    scan(invItem.Power)
    scan(invItem.Value)
    return best
end

local function getPerkStatSum(invItem)
    local total = 0

    local function scan(v)
        if type(v) == "number" then
            total = total + v
        elseif type(v) == "table" then
            for _, x in pairs(v) do scan(x) end
        end
    end

    if invItem then
        scan(invItem.Stats)
        scan(invItem.Stat)
        scan(invItem.Modifiers)
        scan(invItem.Boosts)
        scan(invItem.boosts)
        scan(invItem.Multiplier)
        scan(invItem.Power)
        scan(invItem.Value)
    end

    return total
end

