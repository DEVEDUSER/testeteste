    areaConn = RunService.Heartbeat:Connect(function()
        if not autoFarmArea then return end

        local c = player.Character
        local r = c and c:FindFirstChild("HumanoidRootPart")
        local h = c and c:FindFirstChildOfClass("Humanoid")
        if not r or not h or #farmPoints == 0 then return end

        local target = farmPoints[farmPointIndex]
        local flatR = Vector3.new(r.Position.X, farmAreaCenter.Y, r.Position.Z)
        local flatT = Vector3.new(target.X, farmAreaCenter.Y, target.Z)

        if (flatR - flatT).Magnitude <= 8 then
            farmPointIndex = farmPointIndex + 1
            if farmPointIndex > #farmPoints then farmPointIndex = 1 end
            target = farmPoints[farmPointIndex]
        end

        h:MoveTo(target)

        local flatCenter = Vector3.new(farmAreaCenter.X, r.Position.Y, farmAreaCenter.Z)
        if (r.Position - flatCenter).Magnitude > farmAreaRadius + 80 and os.clock() - farmAreaLastRescue >= 5 then
            farmAreaLastRescue = os.clock()
            r.CFrame = CFrame.new(farmAreaCenter + Vector3.new(0, 4, 0))
        end

        if os.clock() - farmAreaLastRouteRefresh >= 20 then
            if Stats.boxesBroken <= farmAreaLastBoxCount then
                refreshFarmRoute()
                local box = getNearestBox()
                if box and box.CFrame then
                    r.CFrame = CFrame.new(box.CFrame.Position + Vector3.new(0, 4, 0))
                    lastTeleportAt = os.clock()
                end
            else
                farmAreaLastRouteRefresh = os.clock()
                farmAreaLastBoxCount = Stats.boxesBroken
            end
        end
    end)

    local label = area and area.Name or tostring(farmAreaIndex)
    Stats.lastAreaName = label
    notify(I.map .. " Area Farm", "Farmando area " .. tostring(farmAreaIndex) .. " - " .. label, 3)
end

