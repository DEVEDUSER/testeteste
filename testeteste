function sendWebhook(message, force)
    if webhookUrl == "" then
        if not force then notify(I.link .. " Webhook", "Coloque a URL primeiro.", 3) end
        return
    end

    local req = http_request or request or (syn and syn.request) or (fluxus and fluxus.request)
    if not req then
        if not force then notify(I.warn .. " Webhook", "Executor sem request/http_request.", 4) end
        return
    end

    local payload
    if type(message) == "table" then
        payload = message
    else
        payload = {
            username = "Unboxing Hub",
            content = tostring(message),
            allowed_mentions = { parse = {} },
        }
    end

    pcall(function()
        req({
            Url = webhookUrl,
            Method = "POST",
            Headers = { ["Content-Type"] = "application/json" },
            Body = HttpService:JSONEncode(payload),
        })
    end)
end

