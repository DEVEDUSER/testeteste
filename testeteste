    end
end

local function getBoxScore(box, rootPos)
    local pos = box and box.CFrame and box.CFrame.Position
    if not pos then return math.huge end

    local distance = (pos - rootPos).Magnitude
    local name = string.lower(tostring(box.Name or box.Id or box.ModelId or box.Type or ""))
    local priority = tostring(autoAttackPriority or "Nearest")

    if priority == "Small Boxes" then
        local sizeValue = 5
        if typeof(box.Size) == "Vector3" then
            sizeValue = box.Size.Magnitude
        elseif type(box.Size) == "number" then
            sizeValue = box.Size
        end

        return sizeValue * 10 + distance * 0.05
    end

    if priority == "Best Boxes" then
        local bonus = 0
        if name:find("gift") or name:find("present") then bonus = bonus - 1500 end
        if name:find("large") or name:find("big") or name:find("mega") or name:find("giant") then bonus = bonus - 2500 end
        if name:find("rare") or name:find("gold") or name:find("event") then bonus = bonus - 700 end
        return distance + bonus
    end

    if priority == "Low Health" then
        local remaining = math.max((box.Health or 0) - (box.Damage or 0), 0)
        return remaining * 0.1 + distance * 0.02
    end

    return distance
end

local function getNearestBox()
    if not BoxController then return nil end

    local char = player.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not root then return nil end

    local field = BoxController.GetCurrentField(root.Position)
    if not field then return nil end

    local nearest
    local nearestScore = math.huge
    local boxes = field.VisibleBoxes or field.Boxes or {}

    for _, box in pairs(boxes) do
        if box and box.CFrame and box.Health and box.Damage then
            if box.Health > box.Damage and not box.IsOpen then
                local score = getBoxScore(box, root.Position)
                if score < nearestScore then
                    nearest = box
                    nearestScore = score
                end
            end
        end
    end

    return nearest
end

local function buildRoutePoints(center, radius, step)
    local points = {}

    for x = -radius, radius, step do
        local row = {}

        for z = -radius, radius, step do
            if Vector3.new(x, 0, z).Magnitude <= radius then
                table.insert(row, center + Vector3.new(x, 0, z))
            end
        end

        if math.floor((x + radius) / step) % 2 == 1 then
            local rev = {}
            for i = #row, 1, -1 do table.insert(rev, row[i]) end
            row = rev
        end

        for _, p in ipairs(row) do table.insert(points, p) end
    end

    return points
end

local function startTPCameraRoute()
