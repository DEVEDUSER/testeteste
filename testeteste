local function formatTime(seconds)
    seconds = math.floor(seconds)
    local h = math.floor(seconds / 3600)
    local m = math.floor((seconds % 3600) / 60)
    local s = seconds % 60
    return string.format("%02d:%02d:%02d", h, m, s)
end

local function formatNumber(value)
    local str = tostring(math.floor(tonumber(value) or 0))
    local result = str

    while true do
        local changed
        result, changed = result:gsub("^(-?%d+)(%d%d%d)", "%1,%2")
        if changed == 0 then break end
    end

    return result
end

local function logError(systemName, err)
    local key = tostring(systemName or "Core")
    LastError[key] = {
        Message = tostring(err or "Unknown error"),
        Time = os.clock(),
    }
    currentCoreState = "ERROR: " .. key
end

local function safeRun(systemName, fn)
    local ok, result = pcall(fn)
    if not ok then
        logError(systemName, result)
    end
    return ok, result
end

local function canUseCooldown(key, delay)
    local now = os.clock()
    local last = Cooldowns[key] or 0
    if now - last < delay then
        Stats.remoteBlocked = Stats.remoteBlocked + 1
        return false
    end

    Cooldowns[key] = now
    return true
end

local function recordRemote(name, ok, result)
    local info = RemoteStats[name] or {
        Calls = 0,
        Success = 0,
        Failed = 0,
        Last = "Never",
    }

    info.Calls = info.Calls + 1
    info.Last = ok and "OK" or tostring(result)
    if ok then
        info.Success = info.Success + 1
    else
        info.Failed = info.Failed + 1
        logError("Remote " .. tostring(name), result)
    end

    RemoteStats[name] = info
end

local function safeFire(systemName, remote, remoteName, cooldown, ...)
    if not remote then
        logError(systemName, tostring(remoteName) .. " nao encontrado.")
        return false
    end

    local key = tostring(systemName) .. ":" .. tostring(remoteName)
    if cooldown and cooldown > 0 and not canUseCooldown(key, cooldown) then return false end

    local args = { ... }
    local ok, result = pcall(function()
        remote:FireServer(unpack(args))
    end)

    recordRemote(remoteName or systemName, ok, result)
    return ok, result
end

local function safeInvoke(systemName, remote, remoteName, cooldown, ...)
    if not remote then
        logError(systemName, tostring(remoteName) .. " nao encontrado.")
        return false
    end

    local key = tostring(systemName) .. ":" .. tostring(remoteName)
    if cooldown and cooldown > 0 and not canUseCooldown(key, cooldown) then return false end

    local args = { ... }
    local ok, result = pcall(function()
        return remote:InvokeServer(unpack(args))
    end)

    recordRemote(remoteName or systemName, ok, result)
    return ok, result
end

