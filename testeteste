local function getDungeonQueueZone()
    local tagged = CollectionService:GetTagged("DungeonQueue")

    for _, zone in ipairs(tagged) do
        if zone.Name == selectedDungeonDifficulty then
            if selectedDungeonWorld == "Auto" then
                return zone
            end

            local current = zone
            while current and current ~= workspace do
                if current.Name == selectedDungeonWorld then
                    return zone
                end
                current = current.Parent
            end
        end
    end

    local dungeons = workspace:FindFirstChild("Dungeons")
    if not dungeons then return nil end

    if selectedDungeonWorld ~= "Auto" then
        local world = dungeons:FindFirstChild(selectedDungeonWorld)
        local lobby = world and world:FindFirstChild("Lobby")
        local zones = lobby and lobby:FindFirstChild("Zones")
        return zones and zones:FindFirstChild(selectedDungeonDifficulty)
    end

    for _, world in ipairs(dungeons:GetChildren()) do
        local lobby = world:FindFirstChild("Lobby")
        local zones = lobby and lobby:FindFirstChild("Zones")
        local zone = zones and zones:FindFirstChild(selectedDungeonDifficulty)
        if zone then return zone end
    end

    return nil
end

